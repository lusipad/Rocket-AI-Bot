# Rocket.Chat
RC_HOST=localhost
RC_USE_SSL=false
RC_USERNAME=bot
RC_PASSWORD=bot_password

# LLM (CLIProxy OpenAI 兼容端点)
LLM_ENDPOINT=http://localhost:8080/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4

# Azure DevOps Server
AZURE_DEVOPS_URL=http://your-ad-server:8080/tfs
AZURE_DEVOPS_PAT=your-pat
AZURE_DEVOPS_PROJECT=DefaultCollection

# Web 管理页面
WEB_PORT=3001
WEB_SECRET=change-this-to-random-string
