{
  "name": "rocketbot",
  "version": "1.0.0",
  "description": "企业级 Rocket.Chat 机器人 - AI 对话、代码搜索、Codex CLI、Azure DevOps",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "smoke:skills": "node --import tsx scripts/smoke-skill-activation.ts",
    "smoke:commands": "node --import tsx scripts/smoke-command-flow.ts",
    "web-admin:dev": "cd web-admin && npm run dev",
    "web-admin:build": "cd web-admin && npm run build"
  },
  "dependencies": {
    "@rocket.chat/sdk": "^1.0.0-alpha.41",
    "azure-devops-node-api": "^14.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "openai": "^4.86.0",
    "p-limit": "^6.2.0",
    "tiktoken": "^1.0.20",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
